{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://amedeopelliccia.eu/schemas/ledger/tx-principle-imposition/v1",
  "title": "Civilizational Ledger — Principle Imposition Transaction (v1)",
  "description": "Schema for ledger transactions that anchor a corporate-imposition principle declared in a controlled governance document (e.g., README.md §1.4.1). Append-only; corrections via new TX with 'supersedes'.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "tx_id",
    "tx_type",
    "principle_anchor",
    "effective",
    "status",
    "version",
    "issuer",
    "source_document",
    "flow_direction",
    "operational_rules",
    "strategic_alignment",
    "glossary_refs"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri"
    },
    "tx_id": {
      "type": "string",
      "pattern": "^TX-[A-Z0-9-]+-[0-9]{3}$",
      "description": "Canonical transaction identifier. MUST equal the filename (sans .json)."
    },
    "tx_type": {
      "type": "string",
      "const": "principle_imposition"
    },
    "principle_anchor": {
      "type": "string",
      "pattern": "^(PRINCIPLE|AXIOM)-[A-Z0-9-]+-[0-9]{3}$",
      "description": "Anchor declared in a controlled document; resolvable by exact string match."
    },
    "effective": {
      "type": "string",
      "format": "date"
    },
    "status": {
      "type": "string",
      "enum": ["active", "superseded", "suspended", "pending_glossary"]
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "supersedes": {
      "type": ["string", "null"],
      "pattern": "^TX-[A-Z0-9-]+-[0-9]{3}$"
    },
    "issuer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authority", "owner"],
      "properties": {
        "authority": {
          "type": "string",
          "description": "Constitutional authority issuing the TX (e.g., 'Office of the CEO')."
        },
        "owner": {
          "type": "string",
          "description": "Named owner / signer."
        }
      }
    },
    "source_document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "section", "version"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "section": { "type": "string", "minLength": 1 },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        }
      }
    },
    "flow_direction": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["layer", "civilizational_function", "operational_mechanism"],
        "properties": {
          "layer": {
            "type": "string",
            "enum": ["corporations", "civilizational_commons", "human_vertices"]
          },
          "civilizational_function": { "type": "string", "minLength": 1 },
          "operational_mechanism": { "type": "string", "minLength": 1 }
        }
      }
    },
    "operational_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "statement"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^R[0-9]+$"
          },
          "title": { "type": "string", "minLength": 1 },
          "statement": { "type": "string", "minLength": 1 },
          "thresholds": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "floor_ppp_per_month": { "type": "number", "minimum": 0 },
              "ceiling_ppp_per_month": { "type": "number", "minimum": 0 },
              "corporate_tax_circulation_min": {
                "type": "number",
                "minimum": 0,
                "maximum": 1,
                "description": "Minimum admissible fraction of corporate tax that circulates (e.g., 0.95)."
              }
            }
          }
        }
      }
    },
    "strategic_alignment": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ref", "role"],
        "properties": {
          "ref": { "type": "string", "minLength": 1 },
          "role": { "type": "string", "minLength": 1 }
        }
      }
    },
    "glossary_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "description": "Acronym or token expected to be declared in README.md Annex E."
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "superseded" } }, "required": ["status"] },
      "then": { "required": ["supersedes"] }
    }
  ]
}
